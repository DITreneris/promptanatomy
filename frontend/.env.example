# Backend API base URL (no trailing slash)
VITE_API_URL=http://localhost:8000

# Optional: Training app glossary URL. When set, navbar "Repo" opens this link in a new tab.
# VITE_GLOSSARY_URL=https://app.promptuanatomija.lt/glossary

# Optional: X (Twitter) conversion tracking pixel ID. When set, base code loads on all pages (Events Manager → Website).
# VITE_X_PIXEL_ID=r9zms

# Optional: PostHog (funnels, events). Project API Key from PostHog → Project settings.
# EU cloud: set host to https://eu.i.posthog.com
# VITE_POSTHOG_KEY=phc_...
# VITE_POSTHOG_HOST=https://eu.i.posthog.com
