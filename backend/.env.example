# Stripe (use test keys for development)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# One-time Price IDs per plan: 1 = 39 EUR, 2 = 99 EUR, 3 = 149 EUR, 4 = 199 EUR
STRIPE_PRICE_ID_PLAN_1=price_...
STRIPE_PRICE_ID_PLAN_2=price_...
STRIPE_PRICE_ID_PLAN_3=price_...
STRIPE_PRICE_ID_PLAN_4=price_...

# Frontend origin for redirects and CORS (no trailing slash)
# Local: http://localhost:5173  |  Production: https://www.promptanatomy.app
FRONTEND_ORIGIN=http://localhost:5173

# Optional: max tokens per request for token-limited endpoints (default 4096)
# MAX_TOKENS_PER_REQUEST=4096

# Optional: set to 1 only in dev to accept webhooks without STRIPE_WEBHOOK_SECRET (prod must have secret)
# ALLOW_WEBHOOK_WITHOUT_SECRET=0

# Optional: Supabase for MVP upgrade (GET /api/access, webhook upsert, checkout 409 when already purchased)
# Create table with docs/supabase-user-access.sql
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Magic-link redirect to training app (GET /api/success-redirect). Agree same value with training team.
# Generate: openssl rand -base64 32
# ACCESS_TOKEN_SECRET=
# Optional: base URL for redirect (default https://www.promptanatomy.app)
# TRAINING_REDIRECT_BASE=https://www.promptanatomy.app
# Optional: days until link expires (default 30)
# ACCESS_TOKEN_EXPIRY_DAYS=30
