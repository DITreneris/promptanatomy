{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "git submodule update --init --recursive && npm ci && cd frontend && npm ci && cd ../apps/prompt-anatomy && npm ci",
  "buildCommand": "cd frontend && npm run build && cd ../apps/prompt-anatomy && VITE_BASE_PATH=/anatomy/ VITE_MVP_MODE=1 VITE_PUBLIC_SITE_URL=https://www.promptanatomy.app npm run build && mkdir -p ../../frontend/dist/anatomy && cp -r dist/* ../../frontend/dist/anatomy/",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=()"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Link",
          "value": "<https://www.promptanatomy.app/llms.txt>; rel=\"describedby\""
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    },
    {
      "source": "/llms-full.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    },
    {
      "source": "/(.*\\.md)",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ],
  "redirects": [
    { "source": "/anatomija", "destination": "/anatomy/", "permanent": true },
    { "source": "/anatomija/", "destination": "/anatomy/", "permanent": true },
    { "source": "/anatomija/:path*", "destination": "/anatomy/:path*", "permanent": true },
    { "source": "/anatomy", "destination": "/anatomy/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/anatomy/:path*", "destination": "/anatomy/index.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    {
      "source": "/((?!api)(?!anatomy)(?!sitemap\\.xml$)(?!robots\\.txt$)(?!llms\\.txt$)(?!llms-full\\.txt$)(?!privacy\\.md$)(?!terms\\.md$)(?!index\\.en\\.md$)(?!index\\.lt\\.md$).*)",
      "destination": "/index.html"
    }
  ]
}
